{
  "manifest_version": 3,
  "name": "NhapHangChina - Order 1688 & Taobao",
  "version": "1.0.0",
  "description": "Đặt hàng từ 1688.com và Taobao.com về hệ thống NhapHangChina",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://*.1688.com/*",
    "*://*.taobao.com/*",
    "*://*.tmall.com/*",
    "http://localhost:8080/*",
    "http://127.0.0.1:8080/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.1688.com/*"],
      "js": ["content/1688.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.taobao.com/*", "*://*.tmall.com/*"],
      "js": ["content/taobao.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
